# Phase 5 -- esbuild output for the extension build (FSB v0.10.0-attempt-2)
# Bundler-installed-not-wired in Plan 05-01; consumer (offscreen Lattice host)
# lands in Plan 05-04. extension/dist/ is per-developer and never enters git.
extension/dist/

# graphify -- per graphify's own recommendation: cost.json is local-only,
# cache/ is regenerable extraction cache (skip to keep repo small).
graphify-out/**/cost.json
graphify-out/**/cache/
# machine-local state (absolute paths to this machine's interpreter/checkout,
# and a scratch list of not-yet-cached files) -- never portable across machines.
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/.graphify_uncached.txt
