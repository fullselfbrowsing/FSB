  "sideEffectClass": "destructive",
  "params": {
    "type": "object",
    "properties": {
      "chat_id": {
        "type": "string",
        "minLength": 1,
        "description": "Chat ID containing the messages"
      },
      "message_ids": {
        "minItems": 1,
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "description": "Message IDs to revoke (must be messages you sent)"
      }
    },
    "required": [
      "chat_id",
      "message_ids"
    ],
    "additionalProperties": false
  },
