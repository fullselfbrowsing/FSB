{
  "slug": "telegram.delete_messages",
  "service": "web.telegram.org",
  "intentSynonyms": [
    "delete messages in telegram",
    "remove messages in telegram",
    "trash messages in telegram",
    "permanently delete messages in telegram",
    "delete messages from a chat in telegram"
  ],
  "description": "Delete one or more messages from a conversation. Set revoke=true to delete for all participants (only works in private chats and groups where you have permission).",
  "actionVerb": "delete",
  "sideEffectClass": "destructive",
  "params": {
    "type": "object",
    "properties": {
      "peer_id": {
        "type": "number",
        "description": "Peer ID of the conversation"
      },
      "message_ids": {
        "minItems": 1,
        "type": "array",
        "items": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "description": "Array of message IDs to delete"
      },
      "revoke": {
        "description": "Delete for all participants, not just yourself (default false)",
        "type": "boolean"
      }
    },
    "required": [
      "peer_id",
      "message_ids"
    ],
    "additionalProperties": false
  },
