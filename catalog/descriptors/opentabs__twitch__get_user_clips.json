{
  "slug": "twitch.get_user_clips",
  "service": "twitch.tv",
  "intentSynonyms": [
    "get user clips in twitch",
    "look up user clips in twitch",
    "fetch a single user clips in twitch",
    "view one specific user clips in twitch",
    "get clips from a twitch channel in twitch"
  ],
  "description": "Get clips from a Twitch channel sorted by view count. Provide the broadcaster login name and optionally filter by time period.",
  "actionVerb": "get",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "login": {
        "type": "string",
        "description": "Broadcaster login name (e.g., \"shroud\")"
      },
      "period": {
        "description": "Time period filter (default ALL_TIME)",
        "type": "string",
        "enum": [
          "LAST_DAY",
          "LAST_WEEK",
          "LAST_MONTH",
          "ALL_TIME"
        ]
      },
      "first": {
        "description": "Number of clips to return (default 10, max 25)",
        "type": "integer",
        "minimum": 1,
        "maximum": 25
      }
    },
    "required": [
      "login"
    ],
    "additionalProperties": false
  },
  "backing": "dom",
