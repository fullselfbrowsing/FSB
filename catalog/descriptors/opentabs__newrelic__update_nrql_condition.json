        "maximum": 9007199254740991,
        "description": "Account ID"
      },
      "condition_id": {
        "type": "string",
        "minLength": 1,
        "description": "Condition ID to update"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Condition name"
      },
      "nrql_query": {
        "type": "string",
        "minLength": 1,
        "description": "NRQL query"
      },
      "critical_threshold": {
        "type": "number",
        "description": "Critical threshold value"
      },
      "threshold_operator": {
        "description": "Threshold operator (default ABOVE)",
        "type": "string",
        "enum": [
          "ABOVE",
          "BELOW",
          "EQUALS"
        ]
      },
      "threshold_duration": {
        "description": "Duration in seconds (default 300)",
        "type": "integer",
        "minimum": -9007199254740991,
        "maximum": 9007199254740991
      },
      "threshold_occurrences": {
        "description": "Occurrences (default ALL)",
