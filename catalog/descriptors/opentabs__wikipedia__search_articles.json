{
  "slug": "wikipedia.search_articles",
  "service": "wikipedia.org",
  "intentSynonyms": [
    "search articles in wikipedia",
    "search wikipedia for articles matching a query in wikipedia",
    "search wikipedia articles by keyword in wikipedia"
  ],
  "description": "Search Wikipedia articles by keyword. Returns matching articles with snippets, word counts, and timestamps. Supports pagination via offset.",
  "actionVerb": "search",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Search query text"
      },
      "limit": {
        "description": "Maximum number of results to return (default 10, max 50)",
        "type": "integer",
        "minimum": 1,
        "maximum": 50
      },
      "offset": {
        "description": "Offset for pagination (default 0)",
        "type": "integer",
        "minimum": 0,
        "maximum": 9007199254740991
      }
    },
    "required": [
      "query"
    ],
    "additionalProperties": false
  },
  "backing": "dom",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
    "sourcePath": "plugins/wikipedia/src/tools/search-articles.ts",
    "license": "MIT",
    "signals": {
      "transportHelper": "api",
      "httpMethod": "GET",
      "opNameVerb": "search"
    }
  }
}
