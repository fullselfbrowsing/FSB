{
  "slug": "tumblr.get_blog_posts",
  "service": "tumblr.com",
  "intentSynonyms": [
    "get blog posts in tumblr",
    "look up blog posts in tumblr",
    "fetch a single blog posts in tumblr",
    "view one specific blog posts in tumblr",
    "list blog posts in tumblr"
  ],
  "description": "Get posts from a Tumblr blog. Optionally filter by post type or tag.",
  "actionVerb": "get",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "blog_name": {
        "type": "string",
        "description": "Blog name or identifier (e.g., \"staff\" or \"staff.tumblr.com\")"
      },
      "limit": {
        "description": "Number of posts to return (default 20, max 20)",
        "type": "integer",
        "minimum": 1,
        "maximum": 20
      },
      "offset": {
        "description": "Post offset for pagination",
        "type": "integer",
        "minimum": 0,
        "maximum": 9007199254740991
      },
      "type": {
        "description": "Filter by post type",
        "type": "string",
        "enum": [
          "text",
          "photo",
          "quote",
          "link",
          "chat",
          "audio",
          "video"
        ]
      },
      "tag": {
        "description": "Filter posts by tag",
        "type": "string"
      }
    },
    "required": [
      "blog_name"
    ],
    "additionalProperties": false
  },
  "backing": "handler",
