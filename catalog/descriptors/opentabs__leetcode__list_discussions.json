{
  "slug": "leetcode.list_discussions",
  "service": "leetcode.com",
  "intentSynonyms": [
    "list discussions in leetcode",
    "show me my discussions in leetcode",
    "view my discussions in leetcode",
    "see all my discussions in leetcode",
    "list discussion topics for a problem in leetcode"
  ],
  "description": "List discussion topics for a problem. Sorted by most votes by default. Returns topic title, view count, vote count, and creation date.",
  "actionVerb": "list",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "questionId": {
        "type": "string",
        "description": "Question ID (numeric string). Use get_problem to find the questionId."
      },
      "orderBy": {
        "description": "Sort order (default \"most_votes\")",
        "type": "string",
        "enum": [
          "most_votes",
          "newest_to_oldest",
          "most_relevant"
        ]
      },
      "skip": {
        "description": "Number to skip (default 0)",
        "type": "integer",
        "minimum": 0,
        "maximum": 9007199254740991
      },
      "first": {
        "description": "Number of topics (default 10, max 25)",
        "type": "integer",
        "minimum": 1,
        "maximum": 25
      }
    },
    "required": [
      "questionId"
    ],
    "additionalProperties": false
  },
  "backing": "dom",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
