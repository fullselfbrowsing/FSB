      "place": {
        "type": "string",
        "description": "ZIP code or city name (e.g., \"95133\", \"San Jose\")"
      },
      "limit": {
        "description": "Maximum number of stores to return (default 10, max 25)",
        "type": "integer",
        "minimum": 1,
        "maximum": 25
      },
      "radius": {
        "description": "Search radius in miles (default 50)",
        "type": "number",
        "minimum": 1,
        "maximum": 100
      }
    },
