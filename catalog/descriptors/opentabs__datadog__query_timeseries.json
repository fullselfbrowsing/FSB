        "items": {
          "type": "object",
          "properties": {
            "data_source": {
              "type": "string",
              "enum": [
                "metrics",
                "logs",
                "spans",
                "rum"
              ],
              "description": "Data source"
            },
            "query": {
              "type": "string",
              "description": "Query string"
            },
            "name": {
              "type": "string",
              "description": "Query reference name (e.g., \"a\", \"b\")"
