      "title": {
        "type": "string",
        "minLength": 1,
        "description": "Page title"
      },
      "body": {
        "description": "Page body content in storage (HTML) format",
        "type": "string"
      },
      "parent_id": {
        "description": "Parent page ID to nest this page under",
        "type": "string"
      },
      "status": {
        "description": "Page status: \"current\" or \"draft\"",
        "type": "string",
        "enum": [
          "current",
          "draft"
        ]
      }
    },
    "required": [
