{
  "slug": "discord.search_messages",
  "service": "discord.com",
  "intentSynonyms": [
    "search messages in discord",
    "search messages in a server in discord",
    "search for messages in a guild in discord"
  ],
  "description": "Search for messages in a guild. Supports content queries and filters like from:, in:, has:, before:, after:",
  "actionVerb": "search",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "guild_id": {
        "type": "string",
        "minLength": 1,
        "description": "Guild (server) ID to search in"
      },
      "content": {
        "description": "Text content to search for",
        "type": "string"
      },
      "author_id": {
        "description": "Filter by author user ID",
        "type": "string"
      },
      "channel_id": {
        "description": "Filter by channel ID",
        "type": "string"
      },
      "has": {
        "description": "Filter by attachment type: link, embed, file, video, image, sound, sticker",
        "type": "string"
      },
      "limit": {
        "description": "Number of results (default 25, max 25)",
        "type": "integer",
        "minimum": 1,
        "maximum": 25
      },
      "offset": {
        "description": "Result offset for pagination",
        "type": "integer",
        "minimum": 0,
        "maximum": 9007199254740991
      }
    },
    "required": [
      "guild_id"
    ],
    "additionalProperties": false
  },
  "backing": "handler",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
