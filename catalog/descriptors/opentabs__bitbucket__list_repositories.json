{
  "slug": "bitbucket.list_repositories",
  "service": "bitbucket.org",
  "intentSynonyms": [
    "list repositories in bitbucket",
    "show me my repositories in bitbucket",
    "view my repositories in bitbucket",
    "see all my repositories in bitbucket",
    "list repositories in a workspace in bitbucket"
  ],
  "description": "List repositories in a Bitbucket workspace. Supports pagination and filtering with Bitbucket query language.",
  "actionVerb": "list",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "workspace": {
        "type": "string",
        "description": "Workspace slug or UUID"
      },
      "page": {
        "description": "Page number for pagination (default 1)",
        "type": "integer",
        "minimum": -9007199254740991,
        "maximum": 9007199254740991
      },
      "pagelen": {
        "description": "Number of results per page (default 25, max 100)",
        "type": "integer",
        "minimum": -9007199254740991,
        "maximum": 9007199254740991
      },
      "query": {
        "description": "Bitbucket query language filter (e.g., 'name ~ \"my-repo\"')",
        "type": "string"
      }
    },
    "required": [
      "workspace"
    ],
    "additionalProperties": false
  },
