{
  "slug": "steam.get_app_reviews",
  "service": "store.steampowered.com",
  "intentSynonyms": [
    "get app reviews in steam",
    "look up app reviews in steam",
    "fetch a single app reviews in steam",
    "view one specific app reviews in steam",
    "get user reviews for a steam app in steam"
  ],
  "description": "Get user reviews for a Steam app. Returns a review summary (total counts, score label) and individual reviews with text, vote, playtime, and author info. Use cursor for pagination.",
  "actionVerb": "get",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "appid": {
        "type": "integer",
        "minimum": -9007199254740991,
        "maximum": 9007199254740991,
        "description": "Steam app ID"
      },
      "language": {
        "description": "Language filter (default \"all\"). Use \"english\", \"spanish\", etc.",
        "type": "string"
      },
      "num_per_page": {
        "description": "Reviews per page (default 20, max 100)",
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "cursor": {
        "description": "Pagination cursor from a previous response",
        "type": "string"
      },
      "filter": {
        "description": "Review filter (default \"all\")",
        "type": "string",
        "enum": [
          "recent",
          "updated",
          "all"
        ]
      },
      "review_type": {
        "description": "Filter by review sentiment (default \"all\")",
        "type": "string",
        "enum": [
          "all",
          "positive",
          "negative"
        ]
      }
    },
    "required": [
      "appid"
    ],
    "additionalProperties": false
  },
  "backing": "dom",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
    "sourcePath": "plugins/steam/src/tools/get-app-reviews.ts",
    "license": "MIT",
    "signals": {
      "transportHelper": null,
      "httpMethod": null,
      "opNameVerb": "get"
    }
  }
}
