{
  "slug": "twilio.search_available_numbers",
  "service": "console.twilio.com",
  "intentSynonyms": [
    "search available numbers in twilio",
    "search for available phone numbers to buy in twilio",
    "search for available local phone numbers that can be purchased in twilio"
  ],
  "description": "Search for available local phone numbers that can be purchased. Filter by country, area code, or number pattern.",
  "actionVerb": "search",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "country": {
        "description": "ISO country code (default \"US\")",
        "type": "string",
        "minLength": 2,
        "maxLength": 2
      },
      "area_code": {
        "description": "Area code to search within",
        "type": "string"
      },
      "contains": {
        "description": "Number pattern to search for (e.g., \"555\" to find numbers containing 555)",
        "type": "string"
      },
      "page_size": {
        "description": "Number of results to return (default 50, max 1000)",
        "type": "integer",
        "minimum": 1,
        "maximum": 1000
      }
    },
    "additionalProperties": false
  },
  "backing": "dom",
