        "type": "string",
        "enum": [
          "day",
          "week",
          "month",
          "3month",
          "year",
          "all"
        ]
      },
      "interval": {
        "default": "day",
        "description": "Data point interval granularity",
        "type": "string",
        "enum": [
          "5minute",
          "10minute",
          "day",
          "week"
        ]
