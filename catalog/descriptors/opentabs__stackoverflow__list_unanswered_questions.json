{
  "slug": "stackoverflow.list_unanswered_questions",
  "service": "stackoverflow.com",
  "intentSynonyms": [
    "list unanswered questions in stackoverflow",
    "show me my unanswered questions in stackoverflow",
    "view my unanswered questions in stackoverflow",
    "see all my unanswered questions in stackoverflow",
    "list questions with no upvoted answers in stackoverflow"
  ],
