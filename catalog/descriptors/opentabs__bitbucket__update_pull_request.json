{
  "slug": "bitbucket.update_pull_request",
  "service": "bitbucket.org",
  "intentSynonyms": [
    "update a pull request in bitbucket",
    "edit a pull request in bitbucket",
    "change the details of pull request in bitbucket",
    "modify a pull request in bitbucket",
    "update pull request in bitbucket"
  ],
  "description": "Update an existing pull request. Only specified fields are changed; omitted fields remain unchanged.",
