{
  "slug": "outlook.list_messages",
  "service": "outlook.cloud.microsoft",
  "intentSynonyms": [
    "list messages in outlook",
    "show me my messages in outlook",
    "view my messages in outlook",
    "see all my messages in outlook",
    "list emails in a folder in outlook"
  ],
  "description": "List email messages from a mail folder. Defaults to Inbox. Use folder_id to target other folders (get IDs from list_folders). Results are ordered by most recent first.",
  "actionVerb": "list",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "folder_id": {
        "description": "Mail folder ID or well-known name (Inbox, Drafts, SentItems, DeletedItems, Archive). Defaults to Inbox.",
        "type": "string"
      },
      "limit": {
        "description": "Max results (default 10, max 50)",
        "type": "integer",
        "minimum": 1,
        "maximum": 50
      },
      "skip": {
        "description": "Number of messages to skip for pagination",
        "type": "integer",
        "minimum": 0,
        "maximum": 9007199254740991
      },
      "filter": {
        "description": "OData $filter expression (e.g. \"isRead eq false\", \"importance eq 'high'\")",
        "type": "string"
      }
    },
    "additionalProperties": false
  },
  "backing": "dom",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
    "sourcePath": "plugins/outlook/src/tools/list-messages.ts",
    "license": "MIT",
    "signals": {
      "transportHelper": "api",
      "httpMethod": "GET",
      "opNameVerb": "list"
    }
  }
}
