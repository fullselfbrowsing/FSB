    "properties": {
      "calendar_id": {
        "description": "Calendar ID (default \"primary\")",
        "type": "string"
      },
      "event_id": {
        "type": "string",
        "description": "Event ID to delete"
      },
      "send_updates": {
        "description": "Who to send cancellation notifications to (default \"none\")",
        "type": "string",
        "enum": [
          "all",
          "externalOnly",
          "none"
        ]
      }
    },
    "required": [
      "event_id"
    ],
    "additionalProperties": false
  },
