{
  "slug": "asana.list_projects",
  "service": "app.asana.com",
  "intentSynonyms": [
    "list projects in asana",
    "show me my projects in asana",
    "view my projects in asana",
    "see all my projects in asana",
    "list projects in a workspace in asana"
  ],
  "description": "List projects in a workspace. Returns projects sorted by name with optional filtering by archived status. Supports pagination via offset.",
  "actionVerb": "list",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "workspace_gid": {
        "type": "string",
        "minLength": 1,
        "description": "Workspace GID to list projects from"
      },
      "archived": {
        "description": "Filter by archived status (default: false)",
        "type": "boolean"
      },
      "limit": {
        "description": "Results per page (default 20, max 100)",
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "offset": {
        "description": "Pagination offset from a previous response",
        "type": "string"
      }
    },
    "required": [
      "workspace_gid"
    ],
    "additionalProperties": false
  },
  "backing": "dom",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
    "sourcePath": "plugins/asana/src/tools/list-projects.ts",
    "license": "MIT",
    "signals": {
      "transportHelper": "api",
      "httpMethod": "GET",
      "opNameVerb": "list"
    }
  }
}
