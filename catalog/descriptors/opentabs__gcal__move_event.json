  "sideEffectClass": "write",
  "params": {
    "type": "object",
    "properties": {
      "calendar_id": {
        "description": "Source calendar ID (default \"primary\")",
        "type": "string"
      },
      "event_id": {
        "type": "string",
        "description": "Event ID to move"
      },
      "destination": {
        "type": "string",
        "description": "Destination calendar ID to move the event to"
      }
    },
    "required": [
      "event_id",
      "destination"
    ],
    "additionalProperties": false
  },
