{
  "slug": "asana.create_project",
  "service": "app.asana.com",
  "intentSynonyms": [
    "create a project in asana",
    "add a project in asana",
    "make a new project in asana",
    "open a new project in asana",
    "create project in asana",
    "create a new project in a workspace in asana"
  ],
  "description": "Create a new project in a workspace. Requires a workspace GID and project name. Optionally set notes, color, team, dates, and visibility.",
  "actionVerb": "create",
  "sideEffectClass": "write",
  "params": {
    "type": "object",
    "properties": {
      "workspace_gid": {
        "type": "string",
        "minLength": 1,
        "description": "Workspace GID to create the project in"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Project name"
      },
      "notes": {
        "description": "Plain-text project description",
        "type": "string"
      },
      "color": {
        "description": "Project color name (e.g. \"light-green\", \"dark-blue\")",
        "type": "string"
      },
      "team": {
        "description": "Team GID to associate with the project",
        "type": "string"
      },
      "due_on": {
        "description": "Project due date in YYYY-MM-DD format",
        "type": "string"
      },
      "start_on": {
        "description": "Project start date in YYYY-MM-DD format",
        "type": "string"
      },
      "public": {
        "description": "Whether the project is public to the workspace",
        "type": "boolean"
      }
    },
    "required": [
      "workspace_gid",
      "name"
    ],
    "additionalProperties": false
  },
  "backing": "dom",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
    "sourcePath": "plugins/asana/src/tools/create-project.ts",
    "license": "MIT",
    "signals": {
      "transportHelper": "api",
      "httpMethod": "POST",
      "opNameVerb": "create"
    }
  }
}
