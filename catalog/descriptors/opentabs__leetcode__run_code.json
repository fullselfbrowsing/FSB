      },
      "questionId": {
        "type": "string",
        "description": "Question ID (numeric string, e.g., \"1\")"
      },
      "lang": {
        "type": "string",
        "description": "Language slug (e.g., \"python3\", \"java\", \"cpp\", \"javascript\", \"typescript\")"
      },
      "typedCode": {
