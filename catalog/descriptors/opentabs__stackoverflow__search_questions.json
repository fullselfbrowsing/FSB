{
  "slug": "stackoverflow.search_questions",
  "service": "stackoverflow.com",
  "intentSynonyms": [
    "search questions in stackoverflow",
    "search questions with full-text query and filters in stackoverflow",
    "search stack overflow questions using advanced search in stackoverflow"
  ],
  "description": "Search Stack Overflow questions using advanced search. Supports full-text query, tag filtering, date ranges, and multiple sort options. Returns questions with body content. Use this as the primary way to find relevant questions.",
  "actionVerb": "search",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "q": {
        "description": "Full-text search query (e.g., \"react hooks useEffect\")",
        "type": "string"
      },
      "tagged": {
        "description": "Semicolon-delimited tags to filter by (e.g., \"javascript;react\"). Uses AND logic.",
        "type": "string"
      },
      "nottagged": {
        "description": "Semicolon-delimited tags to exclude (e.g., \"jquery;angular\")",
        "type": "string"
      },
      "sort": {
        "description": "Sort order (default: relevance when q is provided, activity otherwise)",
        "type": "string",
        "enum": [
          "activity",
          "creation",
          "votes",
          "relevance"
        ]
      },
      "order": {
        "description": "Sort direction (default: desc)",
        "type": "string",
        "enum": [
          "asc",
          "desc"
        ]
      },
      "accepted": {
        "description": "Filter by whether the question has an accepted answer",
        "type": "boolean"
      },
      "answers": {
        "description": "Minimum number of answers",
        "type": "integer",
        "minimum": -9007199254740991,
        "maximum": 9007199254740991
      },
      "page": {
        "description": "Page number (default 1)",
        "type": "integer",
        "minimum": 1,
        "maximum": 9007199254740991
      },
      "pagesize": {
        "description": "Results per page (default 30, max 100)",
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      }
    },
    "additionalProperties": false
  },
  "backing": "dom",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
    "sourcePath": "plugins/stackoverflow/src/tools/search-questions.ts",
    "license": "MIT",
    "signals": {
      "transportHelper": "api",
      "httpMethod": "GET",
      "opNameVerb": "search"
    }
  }
}
