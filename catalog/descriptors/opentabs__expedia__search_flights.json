{
  "slug": "expedia.search_flights",
  "service": "expedia.com",
  "intentSynonyms": [
    "search flights in expedia",
    "navigate to flight search results in expedia",
    "navigate to the expedia flight search results page for the given route and dates in expedia"
  ],
  "description": "Navigate to the Expedia flight search results page for the given route and dates. The user can view and book flights from the results page. Returns the search URL.",
  "actionVerb": "search",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "origin": {
        "type": "string",
        "description": "Origin airport code or city name (e.g. \"SFO\", \"San Francisco, CA\")"
      },
      "destination": {
        "type": "string",
        "description": "Destination airport code or city name (e.g. \"JFK\", \"New York, NY\")"
      },
      "departure_date": {
        "type": "string",
        "description": "Departure date in YYYY-MM-DD format"
      },
      "return_date": {
        "description": "Return date in YYYY-MM-DD format (omit for one-way)",
        "type": "string"
      },
      "adults": {
        "description": "Number of adults (default 1)",
        "type": "integer",
        "minimum": 1,
        "maximum": 6
      },
      "cabin_class": {
        "description": "Cabin class (default \"coach\")",
        "type": "string",
        "enum": [
          "coach",
          "premium-economy",
          "business",
          "first"
        ]
      }
    },
    "required": [
      "origin",
      "destination",
      "departure_date"
    ],
    "additionalProperties": false
  },
  "backing": "dom",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
    "sourcePath": "plugins/expedia/src/tools/search-flights.ts",
    "license": "MIT",
    "signals": {
      "transportHelper": null,
      "httpMethod": null,
      "opNameVerb": "search"
    }
  }
}
