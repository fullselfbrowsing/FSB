{
  "slug": "posthog.list_events",
  "service": "us.posthog.com",
  "intentSynonyms": [
    "list events in posthog",
    "show me my events in posthog",
    "view my events in posthog",
    "see all my events in posthog",
    "list raw analytics events in posthog"
  ],
  "description": "List raw events from the current PostHog project. Returns individual event occurrences with their properties. Filter by event name, person distinct ID, or date range. Events are ordered by timestamp descending (newest first).",
  "actionVerb": "list",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "event": {
        "description": "Filter by event name (e.g., \"$pageview\", \"server_started\")",
        "type": "string"
      },
      "person_id": {
        "description": "Filter by person distinct ID",
        "type": "string"
      },
      "after": {
        "description": "Only return events after this ISO 8601 timestamp",
        "type": "string"
      },
      "before": {
        "description": "Only return events before this ISO 8601 timestamp",
        "type": "string"
      },
      "limit": {
        "description": "Maximum events to return (default 20, max 100)",
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      }
    },
    "additionalProperties": false
  },
  "backing": "handler",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
    "sourcePath": "plugins/posthog/src/tools/list-events.ts",
    "license": "MIT",
    "signals": {
      "transportHelper": "api",
      "httpMethod": "GET",
      "opNameVerb": "list"
    }
  }
}
