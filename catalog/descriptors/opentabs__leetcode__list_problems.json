{
  "slug": "leetcode.list_problems",
  "service": "leetcode.com",
  "intentSynonyms": [
    "list problems in leetcode",
    "show me my problems in leetcode",
    "view my problems in leetcode",
    "see all my problems in leetcode",
    "browse the problem set in leetcode"
  ],
  "description": "List LeetCode problems with pagination. Optionally filter by category, difficulty, tags, status, and search keyword. Returns problem number, title, difficulty, acceptance rate, and topic tags.",
  "actionVerb": "list",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "categorySlug": {
        "description": "Category slug (e.g., \"algorithms\", \"database\", \"shell\", \"concurrency\")",
        "type": "string"
      },
      "skip": {
        "description": "Number of problems to skip (default 0)",
        "type": "integer",
        "minimum": 0,
        "maximum": 9007199254740991
      },
      "limit": {
        "description": "Number of problems to return (default 20, max 100)",
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      },
      "difficulty": {
        "description": "Filter by difficulty",
        "type": "string",
        "enum": [
          "EASY",
          "MEDIUM",
          "HARD"
        ]
      },
      "status": {
        "description": "Filter by status: NOT_STARTED, AC (accepted), TRIED",
        "type": "string",
        "enum": [
          "NOT_STARTED",
          "AC",
          "TRIED"
        ]
      },
      "tags": {
        "description": "Filter by topic tag slugs (e.g., [\"array\", \"hash-table\"])",
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "searchKeywords": {
        "description": "Search by keyword in problem title",
        "type": "string"
      }
    },
    "additionalProperties": false
  },
  "backing": "dom",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
    "sourcePath": "plugins/leetcode/src/tools/list-problems.ts",
    "license": "MIT",
    "signals": {
      "transportHelper": "graphql",
      "httpMethod": null,
      "opNameVerb": "list"
    }
  }
}
