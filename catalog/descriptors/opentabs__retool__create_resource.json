  ],
  "description": "Create a new resource (data source) in Retool. Resources are connections to external services like REST APIs, databases (PostgreSQL, MySQL), GraphQL endpoints, and more. Once created, queries in apps can reference the resource by name.",
  "actionVerb": "create",
  "sideEffectClass": "write",
  "params": {
    "type": "object",
    "properties": {
      "display_name": {
        "type": "string",
        "description": "Human-readable name for the resource"
      },
      "type": {
        "type": "string",
        "enum": [
          "restapi",
          "postgresql",
          "mysql",
          "graphql",
          "mongodb",
          "redis",
          "snowflake",
          "s3",
          "googlesheets"
        ],
        "description": "Resource type"
      },
      "options": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {},
        "description": "Configuration options (varies by type). For restapi: { baseURL, headers, authentication }. For postgresql: { host, port, databaseName, databaseUsername, databasePassword, ssl }."
      },
      "folder_id": {
        "description": "Resource folder ID (default: root folder)",
        "type": "number"
      }
    },
    "required": [
