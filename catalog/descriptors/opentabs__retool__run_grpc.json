{
  "slug": "retool.run_grpc",
  "service": "retool.com",
  "intentSynonyms": [
    "run a grpc in retool",
    "run grpc in retool",
    "run a grpc method call in retool"
  ],
  "description": "Execute a gRPC method call against a Retool gRPC resource and return the results. Use this to test gRPC resources, call service methods, or validate request/response formats. The resource can be specified by display name or internal UUID.",
