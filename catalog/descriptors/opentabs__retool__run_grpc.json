      },
      "method_name": {
        "type": "string",
        "description": "gRPC method name (e.g., \"ListPlanGroups\", \"SimulatePlan\")"
      },
      "body": {
        "type": "string",
        "description": "JSON request body for the gRPC method"
      },
      "metadata": {
        "description": "Optional gRPC metadata headers",
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {
          "type": "string"
        }
      }
    },
    "required": [
      "resource_name",
      "method_name",
      "body"
    ],
    "additionalProperties": false
  },
  "backing": "handler",
