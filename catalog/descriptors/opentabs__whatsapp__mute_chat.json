        "description": "Chat ID"
      },
      "duration_hours": {
        "type": "integer",
        "minimum": 0,
        "maximum": 9007199254740991,
        "description": "Mute duration in hours. Use 0 to unmute. Common values: 8 (8 hours), 168 (1 week), 8760 (1 year)"
      }
    },
    "required": [
      "chat_id",
      "duration_hours"
    ],
    "additionalProperties": false
  },
