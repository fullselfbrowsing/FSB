{
  "slug": "meticulous.get_test_run_screenshots",
  "service": "app.meticulous.ai",
  "intentSynonyms": [
    "get test run screenshots in meticulous",
    "look up test run screenshots in meticulous",
    "fetch a single test run screenshots in meticulous",
    "view one specific test run screenshots in meticulous",
    "get test run screenshot diffs in meticulous"
  ],
  "description": "Get screenshot diffs and test case screenshots for a test run. Each diff includes head/base replay info and screenshot comparison URLs (base image, head image, diff image).",
  "actionVerb": "get",
  "sideEffectClass": "read",
  "params": {
