        "description": "Max replay diffs to return",
        "type": "number"
      },
      "replay_diff_offset": {
        "default": 0,
        "description": "Offset for replay diffs pagination",
        "type": "number"
      },
      "test_case_limit": {
        "default": 50,
        "description": "Max test case results to return",
        "type": "number"
      },
