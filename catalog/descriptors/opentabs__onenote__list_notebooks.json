{
  "slug": "onenote.list_notebooks",
  "service": "onenote.cloud.microsoft",
  "intentSynonyms": [
    "list notebooks in onenote",
    "show me my notebooks in onenote",
    "view my notebooks in onenote",
    "see all my notebooks in onenote",
    "list all onenote notebooks in onenote"
