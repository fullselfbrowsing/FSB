  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "status": {
        "description": "Filter by status: \"active\" (current), \"upcoming\", \"past\", \"canceled\", \"completed\", or \"pending\"",
        "type": "string",
        "enum": [
          "active",
          "upcoming",
          "past",
          "canceled",
          "completed",
          "pending"
        ]
      },
      "page": {
        "description": "Page number (default 1)",
        "type": "integer",
        "minimum": 1,
        "maximum": 9007199254740991
      }
    },
    "additionalProperties": false
  },
