      },
      "message_id": {
        "type": "integer",
        "minimum": -9007199254740991,
        "maximum": 9007199254740991,
        "description": "ID of the message to pin"
      },
      "silent": {
        "description": "Pin without sending a notification (default false)",
        "type": "boolean"
      }
    },
    "required": [
