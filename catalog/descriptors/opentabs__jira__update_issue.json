{
  "slug": "jira.update_issue",
  "service": "atlassian.net",
  "intentSynonyms": [
    "update an issue in jira",
    "edit an issue in jira",
    "change the details of issue in jira",
    "modify an issue in jira",
    "update issue in jira",
    "update an existing issue in jira"
  ],
  "description": "Update fields on an existing Jira issue. Only specified fields are changed; omitted fields remain unchanged.",
  "actionVerb": "update",
  "sideEffectClass": "write",
  "params": {
    "type": "object",
    "properties": {
      "issue_key": {
        "type": "string",
        "description": "Issue key (e.g. \"KAN-1\") or issue ID"
      },
      "summary": {
        "description": "New issue summary/title",
        "type": "string"
      },
      "description": {
        "description": "New issue description in plain text",
        "type": "string"
      },
      "priority": {
        "description": "New priority name (e.g. \"Highest\", \"High\", \"Medium\", \"Low\", \"Lowest\")",
        "type": "string"
      },
      "assignee_id": {
        "description": "New assignee account ID (use search_users to find IDs). Pass empty string to unassign.",
        "type": "string"
      },
      "labels": {
        "description": "Replace all labels with these values",
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "required": [
      "issue_key"
    ],
    "additionalProperties": false
  },
  "backing": "dom",
