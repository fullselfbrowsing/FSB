{
  "slug": "datadog.list_monitors",
  "service": "datadoghq.com",
  "intentSynonyms": [
    "list monitors in datadog",
    "show me my monitors in datadog",
    "view my monitors in datadog",
    "see all my monitors in datadog",
    "list datadog monitors with optional tag filters in datadog"
  ],
  "description": "List monitors in the Datadog organization. Supports filtering by tags and pagination. Returns monitor details including name, type, query, state, and tags.",
  "actionVerb": "list",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "tags": {
        "description": "Comma-separated tags to filter monitors (e.g., \"env:prod,team:backend\")",
        "type": "string"
      },
      "page": {
        "description": "Page number for pagination (default 0)",
        "type": "integer",
        "minimum": 0,
        "maximum": 9007199254740991
      },
      "per_page": {
        "description": "Monitors per page (default 50, max 100)",
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      }
    },
    "additionalProperties": false
  },
  "backing": "handler",
