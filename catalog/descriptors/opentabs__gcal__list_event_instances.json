{
  "slug": "gcal.list_event_instances",
  "service": "calendar.google.com",
  "intentSynonyms": [
    "list event instances in gcal",
    "show me my event instances in gcal",
    "view my event instances in gcal",
    "see all my event instances in gcal",
    "list instances of a recurring event in gcal"
  ],
  "description": "List individual instances of a recurring event. Use timeMin/timeMax to scope the range of instances returned.",
  "actionVerb": "list",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "calendar_id": {
        "description": "Calendar ID (default \"primary\")",
        "type": "string"
      },
      "event_id": {
        "type": "string",
        "description": "Recurring event ID"
      },
      "time_min": {
        "description": "Lower bound (inclusive) as ISO 8601 timestamp",
        "type": "string"
      },
      "time_max": {
        "description": "Upper bound (exclusive) as ISO 8601 timestamp",
        "type": "string"
      },
      "max_results": {
        "description": "Maximum number of instances to return (default 25)",
        "type": "integer",
        "minimum": 1,
        "maximum": 2500
      },
      "page_token": {
        "description": "Token for fetching the next page",
        "type": "string"
      }
    },
    "required": [
      "event_id"
    ],
    "additionalProperties": false
  },
  "backing": "dom",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
    "sourcePath": "plugins/google-calendar/src/tools/list-event-instances.ts",
    "license": "MIT",
    "signals": {
      "transportHelper": "api",
      "httpMethod": "GET",
      "opNameVerb": "list"
    }
  }
}
