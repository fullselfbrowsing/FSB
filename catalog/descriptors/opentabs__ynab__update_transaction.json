{
  "slug": "ynab.update_transaction",
  "service": "app.ynab.com",
  "intentSynonyms": [
    "update a transaction in ynab",
    "edit a transaction in ynab",
    "change the details of transaction in ynab",
    "modify a transaction in ynab",
    "update transaction in ynab"
  ],
  "description": "Update an existing transaction in the active YNAB plan. Only specified fields are changed; omitted fields remain unchanged. Amount is in currency units (negative for expenses, positive for income). Transfers and split transactions cannot be updated through this tool \u2014 edit them directly in YNAB.",
  "actionVerb": "update",
  "sideEffectClass": "write",
  "params": {
    "type": "object",
    "properties": {
      "transaction_id": {
        "type": "string",
        "minLength": 1,
        "description": "Transaction ID to update"
      },
      "account_id": {
        "type": "string",
        "minLength": 1,
        "description": "Account ID the transaction belongs to"
      },
      "date": {
        "description": "New transaction date in YYYY-MM-DD format",
        "type": "string"
      },
      "amount": {
        "description": "New amount in currency units (negative for expenses, positive for income)",
        "type": "number"
      },
      "payee_name": {
        "description": "New payee name",
        "type": "string"
      },
      "payee_id": {
        "description": "New payee ID",
        "type": "string"
      },
      "category_id": {
        "description": "New category ID",
        "type": "string"
      },
      "memo": {
        "description": "New transaction memo",
        "type": "string"
      },
      "cleared": {
        "description": "New cleared status",
        "type": "string",
        "enum": [
          "cleared",
          "uncleared",
          "reconciled"
        ]
      },
      "approved": {
        "description": "New approval status",
        "type": "boolean"
      },
      "flag_color": {
        "description": "New flag color (pass \"none\" to clear)",
        "type": "string",
        "enum": [
          "red",
          "orange",
          "yellow",
          "green",
          "blue",
          "purple",
          "none"
        ]
      }
    },
    "required": [
      "transaction_id",
      "account_id"
    ],
    "additionalProperties": false
  },
  "backing": "handler",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
    "sourcePath": "plugins/ynab/src/tools/update-transaction.ts",
    "license": "MIT",
    "signals": {
      "transportHelper": null,
      "httpMethod": null,
      "opNameVerb": "update"
    }
  }
}
