      },
      "type": {
        "type": "string",
        "description": "Chart type (e.g., \"ColumnClustered\", \"Line\", \"Pie\", \"Bar\", \"Area\", \"XYScatter\", \"Doughnut\")"
      },
      "source_data": {
        "type": "string",
        "description": "Source data range in A1 notation (e.g., \"A1:C10\")"
      },
      "series_by": {
        "description": "How data series are organized (default \"Auto\")",
        "type": "string",
        "enum": [
          "Auto",
          "Columns",
          "Rows"
        ]
      }
