{
  "slug": "stackoverflow.get_question_answers",
  "service": "stackoverflow.com",
  "intentSynonyms": [
    "get question answers in stackoverflow",
    "look up question answers in stackoverflow",
    "fetch a single question answers in stackoverflow",
    "view one specific question answers in stackoverflow",
    "get answers for a question in stackoverflow"
  ],
  "description": "Get all answers for a specific Stack Overflow question. Returns answer body, score, acceptance status, and author information. Answers can be sorted by activity, creation date, or votes.",
  "actionVerb": "get",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "question_id": {
        "type": "integer",
        "minimum": -9007199254740991,
        "maximum": 9007199254740991,
        "description": "Question ID"
      },
      "sort": {
        "description": "Sort order (default: votes)",
        "type": "string",
        "enum": [
          "activity",
          "creation",
          "votes"
        ]
      },
      "order": {
        "description": "Sort direction (default: desc)",
        "type": "string",
        "enum": [
          "asc",
          "desc"
        ]
      },
      "page": {
        "description": "Page number (default 1)",
        "type": "integer",
        "minimum": 1,
        "maximum": 9007199254740991
      },
      "pagesize": {
        "description": "Results per page (default 30, max 100)",
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      }
    },
    "required": [
      "question_id"
    ],
    "additionalProperties": false
  },
