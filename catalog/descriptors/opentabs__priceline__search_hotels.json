{
  "slug": "priceline.search_hotels",
  "service": "priceline.com",
  "intentSynonyms": [
    "search hotels in priceline",
    "search hotels by city and dates in priceline",
    "search for hotels in a city by location id and travel dates in priceline"
  ],
  "description": "Search for hotels in a city by location ID and travel dates. Returns hotel listings with pricing, ratings, amenities, and availability. Use search_locations first to find the city ID. Date format is YYYYMMDD (e.g., 20260315). Returns up to 30 results per page; use offset for pagination.",
  "actionVerb": "search",
  "sideEffectClass": "read",
  "params": {
    "type": "object",
    "properties": {
      "location_id": {
        "type": "string",
        "description": "City or location ID from search_locations"
      },
      "check_in": {
        "type": "string",
        "description": "Check-in date in YYYYMMDD format (e.g., 20260315)"
      },
      "check_out": {
        "type": "string",
        "description": "Check-out date in YYYYMMDD format (e.g., 20260316)"
      },
      "adults": {
        "description": "Number of adults (default 2)",
        "type": "integer",
        "minimum": 1,
        "maximum": 8
      },
      "rooms": {
        "description": "Number of rooms (default 1)",
        "type": "integer",
        "minimum": 1,
        "maximum": 8
      },
      "sort_by": {
        "description": "Sort order: HDR=recommended, GSR=guest rating, PRC=price, SRN=star rating, DS=distance (default HDR)",
        "type": "string",
        "enum": [
          "HDR",
          "GSR",
          "PRC",
          "SRN",
          "DS"
        ]
      },
      "offset": {
        "description": "Pagination offset (default 0, increments by 30)",
        "type": "integer",
        "minimum": 0,
        "maximum": 9007199254740991
      }
    },
    "required": [
      "location_id",
      "check_in",
      "check_out"
    ],
    "additionalProperties": false
  },
  "backing": "dom",
  "provenance": {
    "source": "opentabs",
    "sha": "4b17021637d2cac12b8d84d21c40e765aa7b85e9",
    "sourcePath": "plugins/priceline/src/tools/search-hotels.ts",
    "license": "MIT",
    "signals": {
      "transportHelper": "graphql",
      "httpMethod": null,
      "opNameVerb": "search"
    }
  }
}
