{
  "schemaVersion": 1,
  "id": "example.get-thing",
  "origin": "https://example.com",
  "endpoint": "/api/{id}",
  "method": "GET",
  "authStrategy": "persisted-query-hash",
  "params": {
    "type": "object",
    "properties": {
      "id": { "type": "string" }
    },
    "required": ["id"]
  },
  "request": {
    "query": { "id": "{id}" }
  },
  "extract": "data.items[*].name"
}
